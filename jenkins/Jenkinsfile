pipeline {
    agent any

    environment {
        SONAR_HOST = 'http://localhost:9000'
        SONAR_TOKEN = credentials('sonartoken')

        APP_VERSION = '1.0.0'
        JAR_NAME = "studysync-${APP_VERSION}.jar"
    }

    stages {

        stage('Checkout') {
            steps {
                echo '>>> Pulling latest code from Git...'
                checkout scm
            }
        }

        stage('Static Code Analysis (SonarQube)') {
            steps {
                echo '>>> Running SonarQube analysis...'
                withSonarQubeEnv('SonarQube') {
                    bat """
                        mvn clean verify sonar:sonar ^
                        -Dsonar.projectKey=studysync ^
                        -Dsonar.host.url=%SONAR_HOST% ^
                        -Dsonar.login=%SONAR_TOKEN%
                    """
                }
            }
        }

        stage('Quality Gate') {
            steps {
                echo '>>> Waiting for SonarQube Quality Gate...'
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Unit Tests + Coverage') {
            steps {
                echo '>>> Running JUnit tests with JaCoCo...'
                bat 'mvn test'
            }

            post {
                always {
                    junit 'target/surefire-reports/*.xml'
                    jacoco(
                        execPattern: 'target/jacoco.exec',
                        classPattern: 'target/classes',
                        sourcePattern: 'src/main/java',
                        minimumLineCoverage: '75'
                    )
                }
            }
        }

        stage('Build') {
            steps {
                echo '>>> Building Spring Boot JAR...'
                bat 'mvn package -DskipTests'
            }

            post {
                success {
                    archiveArtifacts artifacts: "target/${JAR_NAME}", fingerprint: true
                }
            }
        }

        stage('Upload to Artifactory') {
            steps {
                echo '>>> Uploading artifact to Artifactory...'
                bat """
                    curl -u admin:password -T target\\%JAR_NAME% ^
                    "http://localhost:8081/artifactory/studysync-repo/%JAR_NAME%"
                """
            }
        }

        stage('Deploy') {
            steps {
                echo '>>> Deploying StudySync application...'
                bat """
                    taskkill /F /IM java.exe /T || exit /B 0
                    start /B java -jar target\\%JAR_NAME%
                    echo Application running at http://localhost:8080
                """
            }
        }
    }

    post {
        success {
            echo '>>> SUCCESS — Application deployed successfully!'
        }
        failure {
            echo '>>> FAILED — Check logs above'
        }
    }
}